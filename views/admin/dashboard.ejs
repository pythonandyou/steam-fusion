<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Steam Fusion - Admin Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background: #0f0f1a;
            min-height: 100vh;
            color: #e2e8f0;
        }
        
        /* Header */
        .header {
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            padding: 16px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(10px);
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .logo img {
            height: 40px;
        }
        
        .logo-text {
            font-size: 20px;
            font-weight: 700;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .header-actions {
            display: flex;
            gap: 15px;
            align-items: center;
        }
        
        .btn-logout {
            background: rgba(239, 68, 68, 0.15);
            color: #f87171;
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s;
        }
        
        .btn-logout:hover {
            background: rgba(239, 68, 68, 0.3);
        }
        
        /* Main Content */
        .main {
            padding: 30px;
            max-width: 1400px;
            margin: 0 auto;
        }
        
        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 25px;
            transition: all 0.3s;
        }
        
        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }
        
        .stat-label {
            color: #64748b;
            font-size: 14px;
            margin-bottom: 8px;
        }
        
        .stat-value {
            font-size: 32px;
            font-weight: 700;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        /* Content Grid */
        .content-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 30px;
        }
        
        @media (max-width: 1200px) {
            .content-grid {
                grid-template-columns: 1fr;
            }
        }
        
        /* Cards */
        .card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            overflow: hidden;
        }
        
        .card-header {
            padding: 20px 25px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .card-title {
            font-size: 18px;
            font-weight: 600;
        }
        
        .card-body {
            padding: 20px;
        }
        
        /* Buttons */
        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 500;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s;
            border: none;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
        }
        
        .btn-primary:hover {
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
            transform: translateY(-2px);
        }
        
        .btn-sm {
            padding: 6px 12px;
            font-size: 13px;
        }
        
        .btn-danger {
            background: rgba(239, 68, 68, 0.2);
            color: #f87171;
        }
        
        .btn-success {
            background: rgba(34, 197, 94, 0.2);
            color: #4ade80;
        }
        
        .btn-warning {
            background: rgba(234, 179, 8, 0.2);
            color: #facc15;
        }
        
        /* Table */
        .table-container {
            overflow-x: auto;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
        }
        
        th, td {
            padding: 14px 16px;
            text-align: left;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }
        
        th {
            color: #64748b;
            font-weight: 600;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }
        
        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
        
        .badge-success {
            background: rgba(34, 197, 94, 0.2);
            color: #4ade80;
        }
        
        .badge-danger {
            background: rgba(239, 68, 68, 0.2);
            color: #f87171;
        }
        
        .badge-warning {
            background: rgba(234, 179, 8, 0.2);
            color: #facc15;
        }
        
        /* Modal */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            padding: 20px;
        }
        
        .modal-overlay.active {
            display: flex;
        }
        
        .modal {
            background: #1a1a2e;
            border-radius: 16px;
            width: 100%;
            max-width: 500px;
            max-height: 90vh;
            overflow-y: auto;
        }
        
        .modal-header {
            padding: 20px 25px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .modal-title {
            font-size: 18px;
            font-weight: 600;
        }
        
        .modal-close {
            background: none;
            border: none;
            color: #64748b;
            font-size: 24px;
            cursor: pointer;
        }
        
        .modal-body {
            padding: 25px;
        }
        
        .modal-footer {
            padding: 20px 25px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }
        
        /* Form */
        .form-group {
            margin-bottom: 20px;
        }
        
        label {
            display: block;
            color: #a0aec0;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 8px;
        }
        
        input, textarea, select {
            width: 100%;
            padding: 12px 14px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 8px;
            color: #fff;
            font-size: 14px;
            transition: all 0.3s;
        }
        
        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: #667eea;
            background: rgba(255, 255, 255, 0.08);
        }
        
        textarea {
            min-height: 100px;
            resize: vertical;
        }
        
        /* Chart */
        .chart-container {
            padding: 20px;
            height: 300px;
        }
        
        /* Request Items */
        .request-item {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 10px;
        }
        
        .request-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }
        
        .request-from {
            font-weight: 600;
            color: #667eea;
        }
        
        .request-time {
            color: #64748b;
            font-size: 12px;
        }
        
        .request-text {
            color: #cbd5e1;
            font-size: 14px;
            margin-bottom: 10px;
        }
        
        .request-actions {
            display: flex;
            gap: 8px;
        }
        
        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: #64748b;
        }
        
        .empty-state-icon {
            font-size: 48px;
            margin-bottom: 15px;
            opacity: 0.5;
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="logo">
            <img src="/logo.jpg" alt="Steam Fusion">
            <span class="logo-text">Steam Fusion</span>
        </div>
        <div class="header-actions">
            <button class="btn" onclick="openModal('creditHistoryModal')" style="background: rgba(34, 197, 94, 0.2); color: #4ade80;">
                💳 Credit History
            </button>
            <button class="btn" onclick="openModal('backupModal')" style="background: rgba(59, 130, 246, 0.2); color: #60a5fa;">
                💾 Backup
            </button>
            <a href="/logout" class="btn-logout">Logout</a>
        </div>
    </header>
    
    <main class="main">
        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">Total Resellers</div>
                <div class="stat-value"><%= resellers.length %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Total Clients</div>
                <div class="stat-value"><%= totalClients %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Total Credits Distributed</div>
                <div class="stat-value"><%= totalCredits %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Pending Requests</div>
                <div class="stat-value"><%= contentRequests.length %></div>
            </div>
        </div>
        
        <div class="content-grid">
            <!-- Resellers Table -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">Resellers</h2>
                    <button class="btn btn-primary" onclick="openModal('createResellerModal')">+ Add Reseller</button>
                </div>
                <div class="card-body">
                    <div style="margin-bottom: 15px;">
                        <input type="text" id="searchResellers" placeholder="🔍 Search resellers..." oninput="filterResellers()" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #fff;">
                    </div>
                    <div class="table-container">
                        <table id="resellersTable">
                            <thead>
                                <tr>
                                    <th>Username</th>
                                    <th>Credits</th>
                                    <th>Clients</th>
                                    <th>Last Login</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% resellers.forEach(r => { %>
                                <tr data-name="<%= r.username.toLowerCase() %>">
                                    <td><strong><%= r.username %></strong></td>
                                    <td><%= r.credits %> (<%= r.trialCredits || 0 %> trials)</td>
                                    <td><%= r.client_count || 0 %> (<%= r.paid_count || 0 %> paid)</td>
                                    <td>
                                        <% if (r.lastLogin) { %>
                                            <div style="font-size: 12px;">
                                                <div style="white-space: nowrap;"><%= new Date(r.lastLogin).toLocaleString() %></div>
                                                <div style="color: #64748b;">
                                                    <span><%= r.lastIp || 'Unknown' %></span>
                                                    <% if (r.countryName && r.countryName !== 'Unknown') { %>
                                                        <span style="font-size: 11px; opacity: 0.7;"> (<%= r.countryName %>)</span>
                                                    <% } %>
                                                </div>
                                            </div>
                                        <% } else { %>
                                            <span style="color: #64748b;">Never</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <span class="badge <%= r.active ? 'badge-success' : 'badge-danger' %>">
                                            <%= r.active ? 'Active' : 'Disabled' %>
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-primary" onclick="viewReseller(<%= r.id %>)">View</button>
                                        <button class="btn btn-sm btn-info" onclick="showResellerCredentials(<%= r.id %>)" style="background: rgba(59, 130, 246, 0.2); color: #60a5fa;">📋 Login</button>
                                        <button class="btn btn-sm btn-warning" onclick="openAddCreditsModal(<%= r.id %>)">Credits</button>
                                        <button class="btn btn-sm <%= r.active ? 'btn-danger' : 'btn-success' %>" onclick="toggleReseller(<%= r.id %>)">
                                            <%= r.active ? 'Disable' : 'Enable' %>
                                        </button>
                                        <button class="btn btn-sm btn-danger" onclick="deleteReseller(<%= r.id %>)" style="background: rgba(239, 68, 68, 0.3);">🗑️ Delete</button>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            
            <!-- Sidebar -->
            <div>
                <!-- All Clients Section -->
                <div class="card" style="margin-bottom: 20px;">
                    <div class="card-header">
                        <h2 class="card-title">👥 All Clients</h2>
                        <button class="btn btn-sm btn-primary" onclick="loadAllClients()">🔄 Refresh</button>
                    </div>
                    <div class="card-body">
                        <div style="margin-bottom: 15px;">
                            <input type="text" id="searchClients" placeholder="🔍 Search clients..." oninput="filterClients()" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #fff;">
                        </div>
                        <div style="margin-bottom: 10px; display: flex; gap: 10px; flex-wrap: wrap;">
                            <button class="btn btn-sm" onclick="sortAllClients('username')" id="sortBtn-username" style="background: rgba(255,255,255,0.1);">Sort: Name ↕</button>
                            <button class="btn btn-sm" onclick="sortAllClients('status')" id="sortBtn-status" style="background: rgba(255,255,255,0.1);">Status ↕</button>
                            <button class="btn btn-sm" onclick="sortAllClients('lastWatched')" id="sortBtn-lastWatched" style="background: rgba(255,255,255,0.1);">Last Watched ↕</button>
                            <button class="btn btn-sm" onclick="sortAllClients('expiry')" id="sortBtn-expiry" style="background: rgba(255,255,255,0.1);">Expiry ↕</button>
                        </div>
                        <div id="allClientsList" style="max-height: 400px; overflow-y: auto;">
                            <div class="empty-state">
                                <div class="empty-state-icon">👥</div>
                                <p>Click Refresh to load clients</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Expiring Clients -->
                <div class="card" style="margin-bottom: 20px;">
                    <div class="card-header">
                        <h2 class="card-title">⚠️ Expiring Soon (3 days)</h2>
                    </div>
                    <div class="card-body" id="expiringClientsList">
                        <div class="empty-state">
                            <div class="empty-state-icon">📭</div>
                            <p>No clients expiring soon</p>
                        </div>
                    </div>
                </div>
                
                <!-- Expired Clients -->
                <div class="card" style="margin-bottom: 20px;">
                    <div class="card-header">
                        <h2 class="card-title">🚫 Expired Clients</h2>
                    </div>
                    <div class="card-body" id="expiredClientsList">
                        <div class="empty-state">
                            <div class="empty-state-icon">✅</div>
                            <p>No expired clients</p>
                        </div>
                    </div>
                </div>
                
                <!-- Pie Chart -->
                <div class="card" style="margin-bottom: 20px;">
                    <div class="card-header">
                        <h2 class="card-title">Reseller Performance</h2>
                    </div>
                    <div class="chart-container">
                        <canvas id="performanceChart"></canvas>
                    </div>
                </div>
                
                <!-- Content Requests -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="card-title">Content Requests</h2>
                    </div>
                    <div class="card-body">
                        <% if (contentRequests.length === 0) { %>
                            <div class="empty-state">
                                <div class="empty-state-icon">📭</div>
                                <p>No pending requests</p>
                            </div>
                        <% } else { %>
                            <% contentRequests.forEach(cr => { %>
                            <div class="request-item">
                                <div class="request-header">
                                    <span class="request-from">@<%= cr.reseller_name %></span>
                                    <span class="request-time"><%= new Date(cr.createdAt).toLocaleDateString() %></span>
                                </div>
                                <div class="request-text"><%= cr.requestText %></div>
                                <div class="request-actions">
                                    <button class="btn btn-sm btn-success" onclick="respondToRequest(<%= cr.id %>, 'approved')">✓ Approve</button>
                                    <button class="btn btn-sm btn-danger" onclick="respondToRequest(<%= cr.id %>, 'rejected')">✗ Reject</button>
                                </div>
                            </div>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>
    
    <!-- Credit History Modal -->
    <div class="modal-overlay" id="creditHistoryModal">
        <div class="modal" style="max-width: 700px;">
            <div class="modal-header">
                <h3 class="modal-title">💳 Credit History</h3>
                <button class="modal-close" onclick="closeModal('creditHistoryModal')">&times;</button>
            </div>
            <div class="modal-body" id="creditHistoryContent" style="max-height: 400px; overflow-y: auto;">
                Loading...
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('creditHistoryModal')">Close</button>
            </div>
        </div>
    </div>
    
    <!-- Backup Modal -->
    <div class="modal-overlay" id="backupModal">
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">💾 Database Backup</h3>
                <button class="modal-close" onclick="closeModal('backupModal')">&times;</button>
            </div>
            <div class="modal-body">
                <p style="color: #94a3b8; margin-bottom: 20px;">
                    Download a backup of all your data. This includes resellers, clients, transactions, and settings.
                </p>
                <p style="color: #64748b; font-size: 14px;">
                    Backups are also sent to Telegram every week automatically.
                </p>
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('backupModal')">Cancel</button>
                <button class="btn btn-primary" onclick="downloadBackup()">📥 Download Backup</button>
            </div>
        </div>
    </div>
    
    <!-- Edit Expiry Modal -->
    <div class="modal-overlay" id="editExpiryModal">
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">📅 Edit Expiry Date</h3>
                <button class="modal-close" onclick="closeModal('editExpiryModal')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="editExpiryForm">
                    <input type="hidden" id="editClientId">
                    <div class="form-group">
                        <label>Client Username</label>
                        <p id="editClientUsername" style="color: #fff; font-weight: 600;"></p>
                    </div>
                    <div class="form-group">
                        <label>New Expiry Date</label>
                        <input type="datetime-local" id="newExpiryDate" required style="width: 100%; padding: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #fff;">
                    </div>
                    <div class="form-group">
                        <label>Quick Set</label>
                        <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                            <button type="button" class="btn btn-sm" onclick="setExpiryDays(1)">+1 Day</button>
                            <button type="button" class="btn btn-sm" onclick="setExpiryDays(7)">+7 Days</button>
                            <button type="button" class="btn btn-sm" onclick="setExpiryDays(30)">+30 Days</button>
                            <button type="button" class="btn btn-sm" onclick="setExpiryDays(90)">+90 Days</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('editExpiryModal')">Cancel</button>
                <button class="btn btn-primary" onclick="saveExpiryDate()">Save</button>
            </div>
        </div>
    </div>
    
    <!-- Edit Note Modal -->
    <div class="modal-overlay" id="editNoteModal">
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">📝 Edit Note</h3>
                <button class="modal-close" onclick="closeModal('editNoteModal')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="editNoteForm">
                    <input type="hidden" id="editNoteClientId">
                    <div class="form-group">
                        <label>Client</label>
                        <p id="editNoteUsername" style="color: #fff; font-weight: 600;"></p>
                    </div>
                    <div class="form-group">
                        <label>Note</label>
                        <textarea id="clientNote" rows="4" placeholder="Add a note about this client..." style="width: 100%; padding: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #fff; resize: vertical;"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('editNoteModal')">Cancel</button>
                <button class="btn btn-primary" onclick="saveClientNote()">Save</button>
            </div>
        </div>
    </div>
    
    <!-- Transfer Client Modal -->
    <div class="modal-overlay" id="transferClientModal">
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">🔄 Transfer Client</h3>
                <button class="modal-close" onclick="closeModal('transferClientModal')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="transferClientForm">
                    <input type="hidden" id="transferClientId">
                    <div class="form-group">
                        <label>Client</label>
                        <p id="transferClientName" style="color: #fff; font-weight: 600;"></p>
                    </div>
                    <div class="form-group">
                        <label>Current Reseller</label>
                        <p id="transferCurrentReseller" style="color: #94a3b8;"></p>
                    </div>
                    <div class="form-group">
                        <label>New Reseller</label>
                        <select id="transferNewReseller" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #fff;">
                            <!-- Populated dynamically -->
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('transferClientModal')">Cancel</button>
                <button class="btn btn-primary" onclick="transferClient()">Transfer</button>
            </div>
        </div>
    </div>
    
    <!-- Create Reseller Modal -->
    <div class="modal-overlay" id="createResellerModal">
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">Create New Reseller</h3>
                <button class="modal-close" onclick="closeModal('createResellerModal')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="createResellerForm">
                    <div class="form-group">
                        <label>Username</label>
                        <input type="text" name="username" required>
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" name="password" required>
                    </div>
                    <div class="form-group">
                        <label>Note</label>
                        <textarea name="note" placeholder="Optional notes about this reseller..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('createResellerModal')">Cancel</button>
                <button class="btn btn-primary" onclick="createReseller()">Create</button>
            </div>
        </div>
    </div>
    
    <!-- Add Credits Modal -->
    <div class="modal-overlay" id="addCreditsModal">
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">💰 Add Credits</h3>
                <button class="modal-close" onclick="closeModal('addCreditsModal')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="addCreditsForm">
                    <input type="hidden" name="resellerId" id="creditsResellerId">
                    <div class="form-group">
                        <label>Regular Credits</label>
                        <p style="color: #64748b; font-size: 12px; margin-bottom: 8px;">Used for extending trials</p>
                        <input type="number" name="credits" id="addCreditsAmount" min="0" value="10" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #fff;">
                    </div>
                    <div class="form-group" style="margin-top: 15px;">
                        <label>Trial Credits</label>
                        <p style="color: #64748b; font-size: 12px; margin-bottom: 8px;">Used for creating new trials (1 trial = 1 credit)</p>
                        <input type="number" name="trialCredits" id="addTrialCreditsAmount" min="0" value="0" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #fff;">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('addCreditsModal')">Cancel</button>
                <button class="btn btn-primary" onclick="addCredits()">Add Credits</button>
            </div>
        </div>
    </div>
    
    <!-- View Reseller Modal -->
    <div class="modal-overlay" id="viewResellerModal">
        <div class="modal" style="max-width: 700px;">
            <div class="modal-header">
                <h3 class="modal-title">Reseller Details</h3>
                <button class="modal-close" onclick="closeModal('viewResellerModal')">&times;</button>
            </div>
            <div class="modal-body" id="resellerDetails">
                <!-- Populated by JS -->
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('viewResellerModal')">Close</button>
                <button class="btn btn-primary" onclick="openSendMessageModal()">Send Note</button>
            </div>
        </div>
    </div>
    
    <!-- Send Message Modal -->
    <div class="modal-overlay" id="sendMessageModal">
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">Send Note to Reseller</h3>
                <button class="modal-close" onclick="closeModal('sendMessageModal')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="sendMessageForm">
                    <input type="hidden" name="resellerId" id="messageResellerId">
                    <div class="form-group">
                        <label>Message</label>
                        <textarea name="message" required placeholder="Type your message..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('sendMessageModal')">Cancel</button>
                <button class="btn btn-primary" onclick="sendMessage()">Send</button>
            </div>
        </div>
    </div>
    
    <!-- Reseller Credentials Modal -->
    <div class="modal-overlay" id="resellerCredentialsModal">
        <div class="modal" style="max-width: 550px;">
            <div class="modal-header">
                <h3 class="modal-title">📋 Reseller Login Details</h3>
                <button class="modal-close" onclick="closeModal('resellerCredentialsModal')">&times;</button>
            </div>
            <div class="modal-body" id="resellerCredentialsContent">
                <!-- Populated by JS -->
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('resellerCredentialsModal')">Close</button>
                <button class="btn btn-primary" onclick="copyResellerAll()">📋 Copy All</button>
                <button class="btn btn-warning" onclick="resetResellerPassword()" id="resetPasswordBtn">🔄 Reset Password</button>
            </div>
        </div>
    </div>
    
    <!-- Respond to Request Modal -->
    <div class="modal-overlay" id="respondModal">
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">Respond to Request</h3>
                <button class="modal-close" onclick="closeModal('respondModal')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="respondForm">
                    <input type="hidden" name="requestId" id="respondRequestId">
                    <input type="hidden" name="status" id="respondStatus">
                    <div class="form-group">
                        <label>Response</label>
                        <textarea name="response" required placeholder="Your response..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('respondModal')">Cancel</button>
                <button class="btn btn-primary" onclick="submitResponse()">Submit</button>
            </div>
        </div>
    </div>
    
    <script>
        // Modal functions
        function openModal(id) {
            document.getElementById(id).classList.add('active');
        }
        
        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }
        
        // Create reseller
        async function createReseller() {
            const form = document.getElementById('createResellerForm');
            const formData = new FormData(form);
            
            const data = {
                username: formData.get('username'),
                password: formData.get('password'),
                note: formData.get('note')
            };
            
            const res = await fetch('/admin/reseller/create', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            }).then(r => r.json());
            
            if (res.success) {
                location.reload();
            } else {
                alert(res.error || 'Failed to create reseller');
            }
        }
        
        // Add credits modal
        function openAddCreditsModal(resellerId) {
            document.getElementById('creditsResellerId').value = resellerId;
            document.getElementById('addCreditsAmount').value = 10;
            document.getElementById('addTrialCreditsAmount').value = 0;
            openModal('addCreditsModal');
        }
        
        async function addCredits() {
            const resellerId = document.getElementById('creditsResellerId').value;
            const credits = document.getElementById('addCreditsAmount').value;
            const trialCredits = document.getElementById('addTrialCreditsAmount').value;
            
            const res = await fetch('/admin/reseller/add-credits', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    resellerId: resellerId,
                    credits: parseInt(credits) || 0,
                    trialCredits: parseInt(trialCredits) || 0
                })
            }).then(r => r.json());
            
            if (res.success) {
                closeModal('addCreditsModal');
                alert('Added ' + credits + ' regular credits and ' + trialCredits + ' trial credits!');
                location.reload();
            } else {
                alert('Failed to add credits: ' + (res.error || 'Unknown error'));
            }
        }
        
        // Toggle reseller
        async function toggleReseller(resellerId) {
            const res = await fetch('/admin/reseller/toggle', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({resellerId})
            }).then(r => r.json());
            
            if (res.success) {
                location.reload();
            }
        }
        
        // Delete reseller
        async function deleteReseller(resellerId) {
            if (!confirm('Are you sure you want to DELETE this reseller? This will also delete all their clients. This cannot be undone!')) return;
            if (!confirm('LAST WARNING: Delete this reseller permanently?')) return;
            
            const res = await fetch('/admin/reseller/delete', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({resellerId})
            }).then(r => r.json());
            
            if (res.success) {
                alert('Reseller deleted successfully');
                location.reload();
            } else {
                alert(res.error || 'Failed to delete reseller');
            }
        }
        
        // View reseller details
        let currentResellerId = null;
        let currentResellerClients = null;
        async function viewReseller(resellerId) {
            currentResellerId = resellerId;
            const res = await fetch(`/admin/reseller/${resellerId}`).then(r => r.json());
            currentResellerClients = res.clients || [];
            
            let clientsList = '';
            if (res.clients && res.clients.length > 0) {
                clientsList = res.clients.map((c, index) => {
                    const isPaid = c.isPaid || c.is_paid;
                    const expiry = new Date(c.trialEnd).toLocaleDateString();
                    const isExpired = new Date(c.trialEnd) < new Date();
                    const password = c.password || 'N/A';
                    return `
                        <div style="background: rgba(255,255,255,0.05); border-radius: 8px; padding: 12px; margin-bottom: 10px;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                <strong style="color: #fff;">${c.username}</strong>
                                <span class="badge ${isExpired ? 'badge-danger' : (isPaid ? 'badge-success' : 'badge-warning')}">${isExpired ? 'Expired' : (isPaid ? 'Paid' : 'Trial')}</span>
                            </div>
                            <div style="font-size: 13px; color: #94a3b8; margin-bottom: 5px;">Expires: ${expiry}</div>
                            <div style="font-size: 12px; color: #64748b;">Password: ${password}</div>
                            <div style="margin-top: 8px; display: flex; gap: 8px;">
                                <button class="btn btn-sm" onclick="copyClientLogin(${index})" style="background: rgba(59, 130, 246, 0.2); color: #60a5fa;">📋 Copy Login</button>
                                <button class="btn btn-sm btn-danger" onclick="deleteClient(${c.id}, '${c.username}')">Delete</button>
                            </div>
                        </div>
                    `;
                }).join('');
            } else {
                clientsList = '<p style="color: #64748b; text-align: center;">No clients yet</p>';
            }
            
            let html = `
                <div class="form-group">
                    <label>Username</label>
                    <p><strong>${res.reseller.username}</strong></p>
                </div>
                <div class="form-group">
                    <label>Credits</label>
                    <p><strong>${res.reseller.credits}</strong></p>
                </div>
                <div class="form-group">
                    <label>Note</label>
                    <p>${res.reseller.note || 'No notes'}</p>
                </div>
                <div class="form-group">
                    <label>Clients (${res.clients ? res.clients.length : 0})</label>
                    <div style="margin-top: 10px;">
                        ${clientsList}
                    </div>
                </div>
            `;
            
            document.getElementById('resellerDetails').innerHTML = html;
            document.getElementById('messageResellerId').value = resellerId;
            openModal('viewResellerModal');
        }
        
        // Copy client login
        function copyClientLogin(index) {
            if (!currentResellerClients || !currentResellerClients[index]) return;
            
            const client = currentResellerClients[index];
            const password = client.password || 'N/A';
            
            const text = `🎬 Jellyfin Login

Username: ${client.username}
Password: ${password}
Expires: ${new Date(client.trialEnd).toLocaleDateString()}

Login at: ${window.location.origin.replace(':3030', ':8096')}`;
            
            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.style.position = 'fixed';
            textarea.style.left = '-9999px';
            document.body.appendChild(textarea);
            textarea.select();
            
            try {
                document.execCommand('copy');
                alert('✓ Login copied!\n\nUsername: ' + client.username + '\nPassword: ' + password);
            } catch (e) {
                prompt('Copy this:', text);
            }
            
            document.body.removeChild(textarea);
        }
        
        // Delete client from admin view
        async function deleteClient(clientId, username) {
            if (!confirm('Delete client "' + username + '"? This will also remove them from Jellyfin.')) return;
            if (!confirm('LAST WARNING: Delete permanently?')) return;
            
            const res = await fetch('/admin/client/delete', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({clientId})
            }).then(r => r.json());
            
            if (res.success) {
                alert('Client deleted successfully');
                viewReseller(currentResellerId);
            } else {
                alert(res.error || 'Failed to delete');
            }
        }
        
        // Send message
        function openSendMessageModal() {
            closeModal('viewResellerModal');
            openModal('sendMessageModal');
        }
        
        async function sendMessage() {
            const form = document.getElementById('sendMessageForm');
            const formData = new FormData(form);
            
            const data = {
                resellerId: formData.get('resellerId'),
                message: formData.get('message')
            };
            
            const res = await fetch('/admin/message/send', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            }).then(r => r.json());
            
            if (res.success) {
                closeModal('sendMessageModal');
                alert('Message sent!');
            }
        }
        
        // Show reseller credentials
        let currentResellerCreds = null;
        let currentResellerPassword = null;
        async function showResellerCredentials(resellerId) {
            currentResellerCreds = resellerId;
            currentResellerPassword = null;
            
            const res = await fetch(`/admin/reseller/${resellerId}/credentials`).then(r => r.json());
            
            if (!res.success) {
                alert(res.error || 'Failed to get credentials');
                return;
            }
            
            const html = `
                <div style="background: rgba(255,255,255,0.05); border-radius: 10px; padding: 20px; margin-bottom: 15px;">
                    <div style="margin-bottom: 15px;">
                        <label style="color: #64748b; font-size: 12px; display: block; margin-bottom: 5px;">Login URL</label>
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <input type="text" value="${res.loginUrl}" id="credUrl" readonly style="flex: 1; background: rgba(0,0,0,0.3); font-family: monospace; color: #fff; padding: 8px;">
                            <button class="btn btn-sm" onclick="copyTextInput('credUrl', this)">Copy</button>
                        </div>
                    </div>
                    <div style="margin-bottom: 15px;">
                        <label style="color: #64748b; font-size: 12px; display: block; margin-bottom: 5px;">Username</label>
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <input type="text" value="${res.username}" id="credUser" readonly style="flex: 1; background: rgba(0,0,0,0.3); font-family: monospace; color: #fff; padding: 8px;">
                            <button class="btn btn-sm" onclick="copyTextInput('credUser', this)">Copy</button>
                        </div>
                    </div>
                    <div style="margin-bottom: 15px;">
                        <label style="color: #64748b; font-size: 12px; display: block; margin-bottom: 5px;">Password</label>
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <input type="text" value="Click 'Reset Password' below" id="credPass" readonly style="flex: 1; background: rgba(0,0,0,0.3); font-family: monospace; color: #94a3b8; padding: 8px;">
                            <button class="btn btn-sm" onclick="copyTextInput('credPass', this)">Copy</button>
                        </div>
                    </div>
                    ${res.note ? `<div style="margin-bottom: 15px;"><label style="color: #64748b; font-size: 12px; display: block; margin-bottom: 5px;">Note</label><p style="color: #cbd5e1;">${res.note}</p></div>` : ''}
                </div>
                <p style="color: #94a3b8; font-size: 13px; text-align: center; margin-bottom: 15px;">
                    Click <strong>Reset Password</strong> to generate a new password, then click <strong>Copy All</strong> to share with the reseller.
                </p>
            `;
            
            document.getElementById('resellerCredentialsContent').innerHTML = html;
            openModal('resellerCredentialsModal');
        }
        
        // Copy text from input field
        function copyTextInput(inputId, btn) {
            const input = document.getElementById(inputId);
            const text = input.value;
            
            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.style.position = 'fixed';
            textarea.style.left = '-9999px';
            document.body.appendChild(textarea);
            textarea.select();
            
            try {
                document.execCommand('copy');
                const original = btn.innerText;
                btn.innerText = '✓ Done!';
                setTimeout(() => btn.innerText = original, 1500);
            } catch (e) {
                alert('Copy this: ' + text);
            }
            
            document.body.removeChild(textarea);
        }
        
        // Reset reseller password
        async function resetResellerPassword() {
            if (!currentResellerCreds) return;
            
            if (!confirm('Generate a new password for this reseller?')) return;
            
            const res = await fetch('/admin/reseller/reset-password', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ resellerId: currentResellerCreds })
            }).then(r => r.json());
            
            if (res.success) {
                // Store password for Copy All
                currentResellerPassword = res.password;
                
                // Update the password field
                const passwordField = document.getElementById('credPass');
                passwordField.value = res.password;
                passwordField.style.color = '#4ade80';
                
                alert('New password generated!\n\nUsername: ' + res.username + '\nPassword: ' + res.password + '\n\nClick "Copy All" to copy everything.');
            } else {
                alert(res.error || 'Failed to reset password');
            }
        }
        
        // Copy all reseller credentials
        async function copyResellerAll() {
            if (!currentResellerCreds) return;
            
            // Get values directly from input fields
            const urlInput = document.getElementById('credUrl');
            const userInput = document.getElementById('credUser');
            const passInput = document.getElementById('credPass');
            
            const url = urlInput ? urlInput.value : '';
            const username = userInput ? userInput.value : '';
            const password = passInput ? passInput.value : '';
            
            console.log('Copy All - URL:', url);
            console.log('Copy All - Username:', username);
            console.log('Copy All - Password:', password);
            
            // Check if password was generated
            if (!password || password.includes('Click') || password.includes('Reset') || password.includes('generate')) {
                alert('Please click "Reset Password" first to generate a password, then click "Copy All".');
                return;
            }
            
            const text = `🎬 Steam Fusion - Reseller Panel Login

URL: ${url}
Username: ${username}
Password: ${password}

Login to manage your clients and trials!`;
            
            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.style.position = 'fixed';
            textarea.style.left = '-9999px';
            textarea.style.top = '0';
            document.body.appendChild(textarea);
            textarea.focus();
            textarea.select();
            
            try {
                document.execCommand('copy');
                alert('✓ Copied to clipboard!\n\nPassword: ' + password + '\n\nYou can now paste and send to the reseller.');
            } catch (e) {
                prompt('Copy this text:', text);
            }
            
            document.body.removeChild(textarea);
        }
        
        // Respond to content request
        function respondToRequest(requestId, status) {
            document.getElementById('respondRequestId').value = requestId;
            document.getElementById('respondStatus').value = status;
            openModal('respondModal');
        }
        
        async function submitResponse() {
            const form = document.getElementById('respondForm');
            const formData = new FormData(form);
            
            const data = {
                requestId: formData.get('requestId'),
                status: formData.get('status'),
                response: formData.get('response')
            };
            
            const res = await fetch('/admin/content-request/respond', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            }).then(r => r.json());
            
            if (res.success) {
                location.reload();
            }
        }
        
        // Chart
        async function loadChart() {
            const data = await fetch('/api/chart/resellers').then(r => r.json());
            
            new Chart(document.getElementById('performanceChart'), {
                type: 'pie',
                data: {
                    labels: data.map(d => d.username),
                    datasets: [{
                        data: data.map(d => d.client_count),
                        backgroundColor: [
                            '#667eea', '#764ba2', '#f093fb', '#f5576c',
                            '#4facfe', '#00f2fe', '#43e97b', '#38f9d7',
                            '#fa709a', '#fee140', '#30cfd0', '#667eea'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#a0aec0' }
                        }
                    }
                }
            });
        }
        
        // Load expiring clients
        async function loadExpiringClients() {
            const clients = await fetch('/admin/expiring-clients').then(r => r.json());
            const container = document.getElementById('expiringClientsList');
            
            if (clients.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-state-icon">📭</div>
                        <p>No clients expiring soon</p>
                    </div>
                `;
                return;
            }
            
            let html = '';
            clients.forEach(c => {
                const expiryDate = new Date(c.trialEnd).toLocaleDateString();
                html += `
                    <div style="background: rgba(234, 179, 8, 0.1); border: 1px solid rgba(234, 179, 8, 0.3); border-radius: 8px; padding: 12px; margin-bottom: 10px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                            <strong style="color: #facc15;">${c.username}</strong>
                            <span style="font-size: 12px; color: #facc15;">${c.daysUntilExpiry} day${c.daysUntilExpiry !== 1 ? 's' : ''} left</span>
                        </div>
                        <div style="font-size: 12px; color: #94a3b8;">
                            Reseller: ${c.resellerName} | Expires: ${expiryDate}
                        </div>
                    </div>
                `;
            });
            
            container.innerHTML = html;
        }
        
        loadChart();
        loadExpiringClients();
        loadExpiredClients();
        
        // Load expired clients
        async function loadExpiredClients() {
            const clients = await fetch('/admin/clients').then(r => r.json());
            const now = new Date();
            const expiredClients = clients.filter(c => new Date(c.trialEnd) < now);
            
            const container = document.getElementById('expiredClientsList');
            
            if (expiredClients.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-state-icon">✅</div>
                        <p>No expired clients</p>
                    </div>
                `;
                return;
            }
            
            let html = '';
            expiredClients.forEach(c => {
                const expiryDate = new Date(c.trialEnd).toLocaleDateString();
                html += `
                    <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 8px; padding: 12px; margin-bottom: 10px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                            <strong style="color: #f87171;">${c.username}</strong>
                            <div style="display: flex; gap: 5px;">
                                <button class="btn btn-sm" onclick="editExpiry(${c.id}, '${c.username}', '${c.trialEnd}')" style="background: rgba(59, 130, 246, 0.2); color: #60a5fa;">📅 Extend</button>
                                <button class="btn btn-sm" onclick="deleteAdminClient(${c.id}, '${c.username}')" style="background: rgba(239, 68, 68, 0.3); color: #f87171;">🗑️ Delete</button>
                            </div>
                        </div>
                        <div style="font-size: 12px; color: #94a3b8;">
                            Reseller: ${c.resellerName} | Expired: ${expiryDate}
                        </div>
                    </div>
                `;
            });
            
            container.innerHTML = html;
        }
        
        // Delete client from admin panel
        async function deleteAdminClient(clientId, username) {
            if (!confirm(`Delete "${username}" permanently? This will also remove them from Jellyfin.`)) return;
            
            const res = await fetch('/admin/client/delete', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({clientId})
            }).then(r => r.json());
            
            if (res.success) {
                loadExpiredClients();
                loadAllClients();
                alert('Client deleted successfully');
            } else {
                alert(res.error || 'Failed to delete client');
            }
        }
        
        // Filter resellers
        function filterResellers() {
            const search = document.getElementById('searchResellers').value.toLowerCase();
            const rows = document.querySelectorAll('#resellersTable tbody tr');
            
            rows.forEach(row => {
                const name = row.getAttribute('data-name');
                if (name.includes(search)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
        
        // Filter clients
        function filterClients() {
            const search = document.getElementById('searchClients').value.toLowerCase();
            const items = document.querySelectorAll('#allClientsList .client-item');
            
            items.forEach(item => {
                const name = item.getAttribute('data-name');
                const reseller = item.getAttribute('data-reseller');
                if (name.includes(search) || reseller.includes(search)) {
                    item.style.display = '';
                } else {
                    item.style.display = 'none';
                }
            });
        }
        
        // Store clients data globally for sorting
        let allClientsData = [];
        let currentClientSort = { column: 'username', direction: 'asc' };
        
        // Sort all clients
        function sortAllClients(column) {
            // Toggle direction
            if (currentClientSort.column === column) {
                currentClientSort.direction = currentClientSort.direction === 'asc' ? 'desc' : 'asc';
            } else {
                currentClientSort.column = column;
                currentClientSort.direction = 'asc';
            }
            
            // Update button text
            const btn = document.getElementById('sortBtn-' + column);
            if (btn) {
                const arrow = currentClientSort.direction === 'asc' ? '↑' : '↓';
                btn.textContent = btn.textContent.split(' ')[0] + ' ' + arrow;
            }
            
            // Sort and render
            renderClientsList(sortClients(allClientsData, column, currentClientSort.direction));
        }
        
        function sortClients(clients, column, direction) {
            return clients.sort((a, b) => {
                let aVal, bVal;
                
                switch (column) {
                    case 'username':
                        aVal = a.username.toLowerCase();
                        bVal = b.username.toLowerCase();
                        break;
                    case 'status':
                        // Order: Active > Xd left > Expired
                        const getStatusPriority = (c) => {
                            if (c.isExpired) return 2;
                            const daysUntil = Math.ceil((new Date(c.trialEnd) - new Date()) / (1000 * 60 * 60 * 24));
                            if (daysUntil <= 3) return 1;
                            return 0;
                        };
                        aVal = getStatusPriority(a);
                        bVal = getStatusPriority(b);
                        break;
                    case 'lastWatched':
                        aVal = a.lastWatched ? new Date(a.lastWatched).getTime() : 0;
                        bVal = b.lastWatched ? new Date(b.lastWatched).getTime() : 0;
                        break;
                    case 'expiry':
                        aVal = new Date(a.trialEnd).getTime();
                        bVal = new Date(b.trialEnd).getTime();
                        break;
                    default:
                        return 0;
                }
                
                if (direction === 'asc') {
                    return aVal < bVal ? -1 : aVal > bVal ? 1 : 0;
                } else {
                    return aVal > bVal ? -1 : aVal < bVal ? 1 : 0;
                }
            });
        }
        
        function renderClientsList(clients) {
            const container = document.getElementById('allClientsList');
            
            if (clients.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-state-icon">👥</div>
                        <p>No clients yet</p>
                    </div>
                `;
                return;
            }
            
            let html = '<div style="display: flex; flex-direction: column; gap: 8px;">';
            clients.forEach(c => {
                const expiryDate = new Date(c.trialEnd);
                const now = new Date();
                const isExpired = expiryDate < now;
                const daysUntil = Math.ceil((expiryDate - now) / (1000 * 60 * 60 * 24));
                const note = c.note || '';
                
                let statusColor = '#4ade80'; // green
                let statusText = 'Active';
                if (isExpired) {
                    statusColor = '#f87171'; // red
                    statusText = 'Expired';
                } else if (daysUntil <= 3) {
                    statusColor = '#facc15'; // yellow
                    statusText = `${daysUntil}d left`;
                }
                
                // Format last watched
                let lastWatchedText = 'Never';
                if (c.lastWatched) {
                    const lastDate = new Date(c.lastWatched);
                    const diffMs = now - lastDate;
                    const diffMins = Math.floor(diffMs / (1000 * 60));
                    const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
                    const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
                    
                    if (diffMins < 60) {
                        lastWatchedText = `${diffMins}m ago`;
                    } else if (diffHours < 24) {
                        lastWatchedText = `${diffHours}h ago`;
                    } else if (diffDays < 7) {
                        lastWatchedText = `${diffDays}d ago`;
                    } else {
                        lastWatchedText = lastDate.toLocaleDateString();
                    }
                }
                
                // Format IP history
                let ipText = '';
                
                html += `
                    <div class="client-item" data-name="${c.username.toLowerCase()}" data-reseller="${c.resellerName.toLowerCase()}" style="background: rgba(255,255,255,0.05); border-radius: 8px; padding: 10px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                            <div>
                                <div style="color: #fff; font-weight: 500;">${c.username}</div>
                                <div style="font-size: 12px; color: #64748b;">Reseller: ${c.resellerName} | ${expiryDate.toLocaleDateString()}</div>
                            </div>
                            <div style="display: flex; align-items: center; gap: 5px;">
                                <span style="color: ${statusColor}; font-size: 12px; font-weight: 500;">${statusText}</span>
                                <button class="btn btn-sm" onclick="editExpiry(${c.id}, '${c.username}', '${c.trialEnd}')" style="background: rgba(59, 130, 246, 0.2); color: #60a5fa; padding: 4px 8px;" title="Edit expiry">📅</button>
                                <button class="btn btn-sm" onclick="editClientNote(${c.id}, '${c.username}', '${note.replace(/'/g, "\\'")}')" style="background: rgba(234, 179, 8, 0.2); color: #facc15; padding: 4px 8px;" title="Edit note">📝</button>
                                <button class="btn btn-sm" onclick="showTransferModal(${c.id}, '${c.username}', '${c.resellerName}')" style="background: rgba(168, 85, 247, 0.2); color: #a855f7; padding: 4px 8px;" title="Transfer to another reseller">🔄</button>
                            </div>
                        </div>
                        <div style="font-size: 11px; color: #64748b;">
                            <span>📺 ${lastWatchedText}</span>
                            ${note ? `<span style="color: #94a3b8; margin-left: 10px;">📝 ${note}</span>` : ''}
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            
            container.innerHTML = html;
        }
        
        // Load all clients
        async function loadAllClients() {
            const clients = await fetch('/admin/clients').then(r => r.json());
            allClientsData = clients;
            renderClientsList(sortClients(allClientsData, currentClientSort.column, currentClientSort.direction));
        }
        
        // Transfer client modal
        async function showTransferModal(clientId, username, currentReseller) {
            document.getElementById('transferClientId').value = clientId;
            document.getElementById('transferClientName').textContent = username;
            document.getElementById('transferCurrentReseller').textContent = currentReseller;
            
            // Load resellers
            const resellers = await fetch('/admin/resellers').then(r => r.json());
            const select = document.getElementById('transferNewReseller');
            select.innerHTML = resellers
                .filter(r => r.username !== currentReseller)
                .map(r => `<option value="${r.id}">${r.username}</option>`)
                .join('');
            
            openModal('transferClientModal');
        }
        
        // Transfer client
        async function transferClient() {
            const clientId = document.getElementById('transferClientId').value;
            const newResellerId = document.getElementById('transferNewReseller').value;
            
            if (!confirm('Transfer this client to the selected reseller?')) return;
            
            const res = await fetch('/admin/client/transfer', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({clientId, newResellerId})
            }).then(r => r.json());
            
            if (res.success) {
                closeModal('transferClientModal');
                loadAllClients();
                alert(`Client transferred successfully!`);
            } else {
                alert(res.error || 'Failed to transfer');
            }
        }
        
        // Edit client note
        function editClientNote(clientId, username, currentNote) {
            document.getElementById('editNoteClientId').value = clientId;
            document.getElementById('editNoteUsername').textContent = username;
            document.getElementById('clientNote').value = currentNote || '';
            openModal('editNoteModal');
        }
        
        // Save client note
        async function saveClientNote() {
            const clientId = document.getElementById('editNoteClientId').value;
            const note = document.getElementById('clientNote').value;
            
            const res = await fetch('/admin/client/update-note', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({clientId, note})
            }).then(r => r.json());
            
            if (res.success) {
                closeModal('editNoteModal');
                loadAllClients();
                alert('Note saved!');
            } else {
                alert(res.error || 'Failed to save note');
            }
        }
        
        // Edit expiry
        function editExpiry(clientId, username, currentExpiry) {
            document.getElementById('editClientId').value = clientId;
            document.getElementById('editClientUsername').textContent = username;
            
            // Convert to datetime-local format
            const date = new Date(currentExpiry);
            const localDate = new Date(date.getTime() - date.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
            document.getElementById('newExpiryDate').value = localDate;
            
            openModal('editExpiryModal');
        }
        
        // Set expiry to X days from now
        function setExpiryDays(days) {
            const date = new Date();
            date.setDate(date.getDate() + days);
            const localDate = new Date(date.getTime() - date.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
            document.getElementById('newExpiryDate').value = localDate;
        }
        
        // Save expiry date
        async function saveExpiryDate() {
            const clientId = document.getElementById('editClientId').value;
            const newExpiry = document.getElementById('newExpiryDate').value;
            
            if (!newExpiry) {
                alert('Please select a date');
                return;
            }
            
            const res = await fetch('/admin/client/update-expiry', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({clientId, newExpiryDate: newExpiry})
            }).then(r => r.json());
            
            if (res.success) {
                closeModal('editExpiryModal');
                loadAllClients();
                loadExpiringClients();
                alert('Expiry date updated!');
            } else {
                alert(res.error || 'Failed to update');
            }
        }
        
        // Load credit history for admin
        async function loadAdminCreditHistory() {
            const history = await fetch('/admin/credit-history').then(r => r.json());
            const container = document.getElementById('creditHistoryContent');
            
            if (history.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-state-icon">📋</div>
                        <p>No credit history yet</p>
                    </div>
                `;
                return;
            }
            
            let html = '';
            history.forEach(h => {
                const amount = h.amount;
                const isAdd = amount > 0;
                const date = new Date(h.createdAt).toLocaleDateString();
                html += `
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px; border-bottom: 1px solid rgba(255,255,255,0.1);">
                        <div>
                            <div style="color: ${isAdd ? '#4ade80' : '#f87171'}; font-weight: 600;">
                                ${isAdd ? '+' : ''}${amount} credits
                            </div>
                            <div style="font-size: 13px; color: #cbd5e1;">
                                Reseller: <strong>${h.resellerName}</strong>
                            </div>
                            <div style="font-size: 12px; color: #64748b;">${h.note || (isAdd ? 'Added' : 'Used')}</div>
                        </div>
                        <div style="text-align: right;">
                            <div style="font-size: 12px; color: #64748b;">${date}</div>
                            <div style="font-size: 11px; color: #64748b;">by ${h.adminName}</div>
                        </div>
                    </div>
                `;
            });
            
            container.innerHTML = html;
        }
        
        // Download backup
        async function downloadBackup() {
            const backup = await fetch('/admin/backup').then(r => r.json());
            
            const blob = new Blob([JSON.stringify(backup, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `steam-fusion-backup-${new Date().toISOString().split('T')[0]}.json`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
            
            closeModal('backupModal');
            alert('Backup downloaded successfully!');
        }
        
        // Open credit history modal
        document.querySelector('[onclick="openModal(\'creditHistoryModal\')"]')?.addEventListener('click', loadAdminCreditHistory);
    </script>
</body>
</html>