<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Steam Fusion - Reseller Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background: #0f0f1a;
            min-height: 100vh;
            color: #e2e8f0;
        }
        
        /* Header */
        .header {
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            padding: 16px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(10px);
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .logo img {
            height: 40px;
        }
        
        .logo-text {
            font-size: 20px;
            font-weight: 700;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .header-actions {
            display: flex;
            gap: 15px;
            align-items: center;
        }
        
        .credits-badge {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 10px 20px;
            border-radius: 30px;
            font-weight: 600;
        }
        
        .btn-logout {
            background: rgba(239, 68, 68, 0.15);
            color: #f87171;
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s;
        }
        
        .btn-logout:hover {
            background: rgba(239, 68, 68, 0.3);
        }
        
        /* Main Content */
        .main {
            padding: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        /* Alert */
        .alert {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #fca5a5;
            padding: 15px 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .alert-warning {
            background: rgba(234, 179, 8, 0.15);
            border-color: rgba(234, 179, 8, 0.3);
            color: #facc15;
        }
        
        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 25px;
            text-align: center;
        }
        
        .stat-label {
            color: #64748b;
            font-size: 14px;
            margin-bottom: 8px;
        }
        
        .stat-value {
            font-size: 36px;
            font-weight: 700;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        /* Content Grid */
        .content-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 30px;
        }
        
        @media (max-width: 1000px) {
            .content-grid {
                grid-template-columns: 1fr;
            }
        }
        
        /* Cards */
        .card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            overflow: hidden;
        }
        
        .card-header {
            padding: 20px 25px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .card-title {
            font-size: 18px;
            font-weight: 600;
        }
        
        .card-body {
            padding: 20px;
        }
        
        /* Buttons */
        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 500;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s;
            border: none;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
        }
        
        .btn-primary:hover {
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
            transform: translateY(-2px);
        }
        
        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }
        
        .btn-sm {
            padding: 6px 12px;
            font-size: 13px;
        }
        
        .btn-success {
            background: rgba(34, 197, 94, 0.2);
            color: #4ade80;
        }
        
        .btn-warning {
            background: rgba(234, 179, 8, 0.2);
            color: #facc15;
        }
        
        .btn-danger {
            background: rgba(239, 68, 68, 0.2);
            color: #f87171;
        }
        
        /* Table */
        .table-container {
            overflow-x: auto;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
        }
        
        th, td {
            padding: 14px 16px;
            text-align: left;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }
        
        th {
            color: #64748b;
            font-weight: 600;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }
        
        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
        
        .badge-success {
            background: rgba(34, 197, 94, 0.2);
            color: #4ade80;
        }
        
        .badge-warning {
            background: rgba(234, 179, 8, 0.2);
            color: #facc15;
        }
        
        .badge-danger {
            background: rgba(239, 68, 68, 0.2);
            color: #f87171;
        }
        
        .expiry-date {
            color: #94a3b8;
            font-size: 13px;
        }
        
        .expiry-date.urgent {
            color: #f87171;
            font-weight: 600;
        }
        
        .days-remaining {
            font-size: 11px;
            color: #64748b;
        }
        
        /* Modal */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            padding: 20px;
        }
        
        .modal-overlay.active {
            display: flex;
        }
        
        .modal {
            background: #1a1a2e;
            border-radius: 16px;
            width: 100%;
            max-width: 500px;
        }
        
        .modal-header {
            padding: 20px 25px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .modal-title {
            font-size: 18px;
            font-weight: 600;
        }
        
        .modal-close {
            background: none;
            border: none;
            color: #64748b;
            font-size: 24px;
            cursor: pointer;
        }
        
        .modal-body {
            padding: 25px;
        }
        
        .modal-footer {
            padding: 20px 25px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }
        
        /* Form */
        .form-group {
            margin-bottom: 20px;
        }
        
        label {
            display: block;
            color: #a0aec0;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 8px;
        }
        
        input, textarea {
            width: 100%;
            padding: 12px 14px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 8px;
            color: #fff;
            font-size: 14px;
            transition: all 0.3s;
        }
        
        input:focus, textarea:focus {
            outline: none;
            border-color: #667eea;
            background: rgba(255, 255, 255, 0.08);
        }
        
        textarea {
            min-height: 100px;
            resize: vertical;
        }
        
        .hint {
            font-size: 12px;
            color: #64748b;
            margin-top: 5px;
        }
        
        /* Message Items */
        .message-item {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 10px;
            position: relative;
        }
        
        .message-item.unread {
            background: rgba(102, 126, 234, 0.1);
            border-left: 3px solid #667eea;
        }
        
        .message-time {
            color: #64748b;
            font-size: 12px;
            margin-bottom: 5px;
        }
        
        .message-text {
            color: #cbd5e1;
            font-size: 14px;
        }
        
        /* Request Items */
        .request-item {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 10px;
        }
        
        .request-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }
        
        .request-status {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
        
        .request-status.pending {
            background: rgba(234, 179, 8, 0.2);
            color: #facc15;
        }
        
        .request-status.approved {
            background: rgba(34, 197, 94, 0.2);
            color: #4ade80;
        }
        
        .request-status.rejected {
            background: rgba(239, 68, 68, 0.2);
            color: #f87171;
        }
        
        .request-text {
            color: #cbd5e1;
            font-size: 14px;
            margin-bottom: 10px;
        }
        
        .request-response {
            background: rgba(255, 255, 255, 0.05);
            padding: 10px;
            border-radius: 6px;
            font-size: 13px;
            color: #94a3b8;
        }
        
        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: #64748b;
        }
        
        .empty-state-icon {
            font-size: 48px;
            margin-bottom: 15px;
            opacity: 0.5;
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="logo">
            <img src="/logo.jpg" alt="Steam Fusion">
            <span class="logo-text">Steam Fusion</span>
        </div>
        <div class="header-actions">
            <div class="credits-badge">🎫 <%= reseller.credits %> Credits</div>
            <a href="/logout" class="btn-logout">Logout</a>
        </div>
    </header>
    
    <main class="main">
        <!-- Low Credits Warning -->
        <% if (reseller.credits < 2) { %>
        <div class="alert">
            ⚠️ <strong>Low Credits!</strong> You have <%= reseller.credits %> credits. You need at least 2 credits to create trials. Please purchase more credits.
        </div>
        <% } %>
        
        <% if (!reseller.active) { %>
        <div class="alert">
            🚫 Your account has been disabled. Contact the admin.
        </div>
        <% } %>
        
        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">Your Credits</div>
                <div class="stat-value"><%= reseller.credits %></div>
                <div style="font-size: 12px; color: #64748b;">For extending</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Trial Credits</div>
                <div class="stat-value"><%= reseller.trialCredits || 0 %></div>
                <div style="font-size: 12px; color: #64748b;">For new trials</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Total Clients</div>
                <div class="stat-value"><%= clients.length %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Active Clients</div>
                <div class="stat-value"><%= clients.filter(c => !c.isExpired).length %></div>
            </div>
        </div>
        
        <!-- Expiring Soon Alert -->
        <div id="expiringAlert" style="display: none; margin-bottom: 20px;">
            <div class="card" style="background: rgba(234, 179, 8, 0.1); border: 1px solid rgba(234, 179, 8, 0.3);">
                <div style="padding: 15px;">
                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
                        <span style="font-size: 18px;">⚠️</span>
                        <span style="font-weight: 600; color: #facc15;">Expiring Soon (<span id="expiringCount">0</span>)</span>
                    </div>
                    <div id="expiringList" style="margin-top: 10px;"></div>
                </div>
            </div>
        </div>
        
        <!-- Previous Login Info -->
        <% if (reseller.previousLogin) { %>
        <div class="card" style="margin-bottom: 20px; background: rgba(234, 179, 8, 0.1); border: 1px solid rgba(234, 179, 8, 0.2);">
            <div style="padding: 15px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 5px;">
                    <span style="font-size: 18px;">🔐</span>
                    <span style="font-weight: 600; color: #facc15;">Previous Login</span>
                </div>
                <div style="color: #cbd5e1; font-size: 14px;">
                    <strong>Time:</strong> <%= new Date(reseller.previousLogin).toLocaleString() %>
                </div>
                <div style="color: #94a3b8; font-size: 13px;">
                    <strong>IP:</strong> <%= reseller.previousIp || 'Unknown' %>
                    <% if (reseller.previousCountryName && reseller.previousCountryName !== 'Unknown') { %>
                        <span style="margin-left: 5px;">(<%= reseller.previousCountryName %>)</span>
                    <% } %>
                </div>
            </div>
        </div>
        <% } else if (reseller.lastLogin) { %>
        <div class="card" style="margin-bottom: 20px; background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.2);">
            <div style="padding: 15px;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 5px;">
                    <span style="font-size: 18px;">🔐</span>
                    <span style="font-weight: 600; color: #60a5fa;">First Login</span>
                </div>
                <div style="color: #cbd5e1; font-size: 14px;">
                    <strong>Time:</strong> <%= new Date(reseller.lastLogin).toLocaleString() %>
                </div>
                <div style="color: #94a3b8; font-size: 13px;">
                    <strong>IP:</strong> <%= reseller.lastIp || 'Unknown' %>
                    <% if (reseller.countryName && reseller.countryName !== 'Unknown') { %>
                        <span style="margin-left: 5px;">(<%= reseller.countryName %>)</span>
                    <% } %>
                </div>
            </div>
        </div>
        <% } %>
        
        <div class="content-grid">
            <!-- Clients Table -->
            <div>
                <div class="card" style="margin-bottom: 20px;">
                    <div class="card-header">
                        <h2 class="card-title">Your Clients</h2>
                        <button class="btn btn-primary" onclick="openModal('createTrialModal')" <%= !canGiveTrial ? 'disabled' : '' %>>
                            + Create Trial
                        </button>
                    </div>
                    <div class="card-body">
                        <% if (clients.length === 0) { %>
                            <div class="empty-state">
                                <div class="empty-state-icon">👥</div>
                                <p>No clients yet. Create your first trial!</p>
                            </div>
                        <% } else { %>
                        <div style="margin-bottom: 15px;">
                            <input type="text" id="searchClients" placeholder="🔍 Search clients..." oninput="filterClients()" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #fff;">
                        </div>
                        <div class="table-container">
                            <table id="clientsTable">
                                <thead>
                                    <tr>
                                        <th class="sortable" onclick="sortClients('username')" style="cursor: pointer;">Username <span id="sort-username">↕</span></th>
                                        <th class="sortable" onclick="sortClients('status')" style="cursor: pointer;">Status <span id="sort-status">↕</span></th>
                                        <th class="sortable" onclick="sortClients('lastWatched')" style="cursor: pointer;">Last Watched <span id="sort-lastWatched">↕</span></th>
                                        <th class="sortable" onclick="sortClients('expiry')" style="cursor: pointer;">Expires <span id="sort-expiry">↕</span></th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="clientsTableBody">
                                    <% clients.forEach(c => { 
                                        // Format last watched
                                        let lastWatchedText = 'Never';
                                        if (c.lastWatched) {
                                            const lastDate = new Date(c.lastWatched);
                                            const now = new Date();
                                            const diffMs = now - lastDate;
                                            const diffMins = Math.floor(diffMs / (1000 * 60));
                                            const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
                                            const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
                                            
                                            if (diffMins < 60) {
                                                lastWatchedText = diffMins + 'm ago';
                                            } else if (diffHours < 24) {
                                                lastWatchedText = diffHours + 'h ago';
                                            } else if (diffDays < 7) {
                                                lastWatchedText = diffDays + 'd ago';
                                            } else {
                                                lastWatchedText = lastDate.toLocaleDateString();
                                            }
                                        }
                                        
                                        // Format IP history
                                        let ipText = '-';
                                        if (c.ipHistory && c.ipHistory.length > 0) {
                                            const recentIps = c.ipHistory.slice(0, 2);
                                            ipText = recentIps.map(ip => ip.ip).join('<br>');
                                        }
                                    %>
                                    <tr data-name="<%= c.username.toLowerCase() %>">
                                        <td><strong><%= c.username %></strong></td>
                                        <td>
                                            <% if (c.isExpired) { %>
                                                <span class="badge badge-danger">Expired</span>
                                            <% } else if (c.isPaid) { %>
                                                <span class="badge badge-success">Paid</span>
                                            <% } else { %>
                                                <span class="badge badge-warning">Trial</span>
                                            <% } %>
                                        </td>
                                        <td style="font-size: 12px; color: #94a3b8;"><%= lastWatchedText %></td>
                                        <td>
                                            <% if (c.isExpired) { %>
                                                <span class="expiry-date urgent">EXPIRED</span>
                                            <% } else { %>
                                                <span class="expiry-date"><%= new Date(c.trialEnd).toLocaleDateString() %></span>
                                                <div class="days-remaining"><%= c.daysRemaining %> days remaining</div>
                                            <% } %>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-info" onclick="showCredentials(<%= c.id %>)" style="background: rgba(59, 130, 246, 0.2); color: #60a5fa;">
                                                📋 Credentials
                                            </button>
                                            <button class="btn btn-sm btn-success" onclick="extendTrial(<%= c.id %>, 1)">
                                                +1 Month
                                            </button>
                                            <button class="btn btn-sm btn-warning" onclick="extendTrial(<%= c.id %>, 3)" style="margin-left: 5px;">
                                                +3 Months
                                            </button>
                                            <button class="btn btn-sm btn-info" onclick="resetClientPassword(<%= c.id %>, '<%= c.username %>')" style="margin-left: 5px; background: rgba(59, 130, 246, 0.2); color: #60a5fa;">
                                                🔑 Reset PW
                                            </button>
                                            <button class="btn btn-sm" onclick="editClientNote(<%= c.id %>, '<%= c.username %>')" style="margin-left: 5px; background: rgba(234, 179, 8, 0.2); color: #facc15;">
                                                📝 Note
                                            </button>
                                            <button class="btn btn-sm <%= c.disabled ? 'btn-success' : 'btn-danger' %>" onclick="toggleClient(<%= c.id %>, '<%= c.username %>', <%= c.disabled ? true : false %>)" style="margin-left: 5px;">
                                                <%= c.disabled ? 'Enable' : 'Disable' %>
                                            </button>
                                            <button class="btn btn-sm btn-danger" onclick="deleteClient(<%= c.id %>, '<%= c.username %>')" style="margin-left: 5px;">
                                                Delete
                                            </button>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>
                    </div>
                </div>
                
                <!-- Content Requests -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="card-title">Content Requests</h2>
                        <button class="btn btn-primary" onclick="openModal('requestModal')">+ New Request</button>
                    </div>
                    <div class="card-body">
                        <% if (contentRequests.length === 0) { %>
                            <div class="empty-state">
                                <div class="empty-state-icon">📭</div>
                                <p>No requests yet. Request content you need!</p>
                            </div>
                        <% } else { %>
                            <% contentRequests.forEach(cr => { %>
                            <div class="request-item">
                                <div class="request-header">
                                    <span class="request-time"><%= new Date(cr.createdAt).toLocaleDateString() %></span>
                                    <span class="request-status <%= cr.status %>"><%= cr.status %></span>
                                </div>
                                <div class="request-text"><%= cr.requestText %></div>
                                <% if (cr.adminResponse) { %>
                                <div class="request-response">
                                    <strong>Admin:</strong> <%= cr.adminResponse %>
                                </div>
                                <% } %>
                            </div>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
            </div>
            
            <!-- Messages -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">Messages from Admin</h2>
                </div>
                <div class="card-body">
                    <% if (messages.length === 0) { %>
                        <div class="empty-state">
                            <div class="empty-state-icon">✉️</div>
                            <p>No messages yet</p>
                        </div>
                    <% } else { %>
                        <% messages.forEach(m => { %>
                        <div class="message-item <%= m.read ? '' : 'unread' %>">
                            <div class="message-time"><%= new Date(m.createdAt).toLocaleString() %></div>
                            <div class="message-text"><%= m.message %></div>
                            <% if (!m.read) { %>
                            <button class="btn btn-sm btn-primary" style="margin-top: 10px;" onclick="markAsRead(<%= m.id %>)">Mark as Read</button>
                            <% } %>
                        </div>
                        <% }); %>
                    <% } %>
                </div>
            </div>
        </div>
        
        <!-- Expired Clients -->
        <div class="card" style="margin-top: 20px;">
            <div class="card-header">
                <h2 class="card-title">🚫 Expired Clients</h2>
            </div>
            <div class="card-body" id="expiredClientsList">
                <div class="empty-state">
                    <div class="empty-state-icon">✅</div>
                    <p>No expired clients</p>
                </div>
            </div>
        </div>
        
        <!-- Credit History -->
        <div class="card" style="margin-top: 20px;">
            <div class="card-header">
                <h2 class="card-title">💳 Credit History</h2>
            </div>
            <div class="card-body" id="creditHistoryList">
                <div class="empty-state">
                    <div class="empty-state-icon">📋</div>
                    <p>Loading...</p>
                </div>
            </div>
        </div>
    </main>
    
    <!-- Create Trial Modal -->
    <div class="modal-overlay" id="createTrialModal">
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">Create Trial User</h3>
                <button class="modal-close" onclick="closeModal('createTrialModal')">&times;</button>
            </div>
            <div class="modal-body">
                <p style="color: #94a3b8; margin-bottom: 20px;">
                    Create a trial account with 1 month access. This will use 1 trial credit.
                </p>
                <form id="createTrialForm">
                    <div class="form-group">
                        <label>Username *</label>
                        <input type="text" name="username" required placeholder="Enter username">
                    </div>
                    <div class="form-group">
                        <label>Password (optional)</label>
                        <input type="text" name="password" placeholder="Leave empty for auto-generated">
                        <p class="hint">If empty, a random password will be generated</p>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('createTrialModal')">Cancel</button>
                <button class="btn btn-primary" onclick="createTrial()">Create Trial</button>
            </div>
        </div>
    </div>
    
    <!-- Request Content Modal -->
    <div class="modal-overlay" id="requestModal">
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">Request Content</h3>
                <button class="modal-close" onclick="closeModal('requestModal')">&times;</button>
            </div>
            <div class="modal-body">
                <p style="color: #94a3b8; margin-bottom: 20px;">
                    Request movies, series, or other content to be added.
                </p>
                <form id="requestForm">
                    <div class="form-group">
                        <label>What do you need?</label>
                        <textarea name="request" required placeholder="E.g., 'The Batman 2022' or 'Stranger Things Season 4'"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('requestModal')">Cancel</button>
                <button class="btn btn-primary" onclick="submitRequest()">Submit Request</button>
            </div>
        </div>
    </div>
    
    <!-- Credentials Modal -->
    <div class="modal-overlay" id="credentialsModal">
        <div class="modal" style="max-width: 550px;">
            <div class="modal-header">
                <h3 class="modal-title">📋 Client Credentials</h3>
                <button class="modal-close" onclick="closeModal('credentialsModal')">&times;</button>
            </div>
            <div class="modal-body" id="credentialsContent">
                <!-- Populated by JS -->
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('credentialsModal')">Close</button>
                <button class="btn btn-primary" onclick="copyCredentials()">📋 Copy All</button>
            </div>
        </div>
    </div>
    
    <!-- Note Modal -->
    <div class="modal-overlay" id="noteModal">
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">📝 Edit Note</h3>
                <button class="modal-close" onclick="closeModal('noteModal')">&times;</button>
            </div>
            <div class="modal-body">
                <form id="noteForm">
                    <input type="hidden" id="noteClientId">
                    <div class="form-group">
                        <label>Client</label>
                        <p id="noteClientName" style="color: #fff; font-weight: 600;"></p>
                    </div>
                    <div class="form-group">
                        <label>Note</label>
                        <textarea id="clientNoteText" rows="4" placeholder="Add a note about this client..." style="width: 100%; padding: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #fff; resize: vertical;"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn" onclick="closeModal('noteModal')">Cancel</button>
                <button class="btn btn-primary" onclick="saveClientNote()">Save</button>
            </div>
        </div>
    </div>
    
    <script>
        // Modal functions
        function openModal(id) {
            document.getElementById(id).classList.add('active');
        }
        
        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }
        
        // Create trial
        async function createTrial() {
            const form = document.getElementById('createTrialForm');
            const formData = new FormData(form);
            
            const data = {
                username: formData.get('username'),
                password: formData.get('password')
            };
            
            const res = await fetch('/reseller/trial/create', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            }).then(r => r.json());
            
            if (res.success) {
                alert(`Trial created!\n\nUsername: ${res.username}\nPassword: ${res.password}\n\nTrial credits left: ${res.trialCreditsLeft}\n\nUser can login to Jellyfin now.`);
                location.reload();
            } else {
                alert(res.error || 'Failed to create trial');
            }
        }
        
        // Extend trial
        async function extendTrial(clientId, months) {
            if (!confirm(`Add ${months} month(s) to this client? This will cost ${months} credit(s) and you will receive ${months} trial credit(s) back.`)) return;
            
            const res = await fetch('/reseller/trial/extend', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({clientId, months})
            }).then(r => r.json());
            
            if (res.success) {
                alert(`Extended by ${months} month(s)!\n\nNew expiry: ${new Date(res.newEnd).toLocaleDateString()}\nTrial credits received: ${res.trialCreditsReceived}\nYour trial credits: ${res.trialCreditsLeft}`);
                location.reload();
            } else {
                alert(res.error || 'Failed to extend');
            }
        }
        
        // Submit content request
        async function submitRequest() {
            const form = document.getElementById('requestForm');
            const formData = new FormData(form);
            
            const data = {
                request: formData.get('request')
            };
            
            const res = await fetch('/reseller/content-request', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            }).then(r => r.json());
            
            if (res.success) {
                alert('Request submitted!');
                location.reload();
            }
        }
        
        // Mark message as read
        async function markAsRead(messageId) {
            await fetch('/reseller/message/read', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({messageId})
            });
            location.reload();
        }
        
        // Load expiring clients
        async function loadExpiringClients() {
            const clients = await fetch('/reseller/expiring-clients').then(r => r.json());
            
            // Update the stat
            document.getElementById('expiringCount').innerText = clients.length;
            
            if (clients.length === 0) {
                document.getElementById('expiringAlert').style.display = 'none';
                return;
            }
            
            // Show alert
            document.getElementById('expiringAlert').style.display = 'block';
            
            // Build list
            let html = '';
            clients.forEach(c => {
                const expiryDate = new Date(c.trialEnd).toLocaleDateString();
                html += `
                    <div style="background: rgba(0,0,0,0.2); border-radius: 6px; padding: 10px; margin-top: 8px; display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <strong style="color: #facc15;">${c.username}</strong>
                            <div style="font-size: 12px; color: #94a3b8;">Expires: ${expiryDate}</div>
                        </div>
                        <div style="text-align: right;">
                            <span style="color: #facc15; font-weight: 600;">${c.daysUntilExpiry} day${c.daysUntilExpiry !== 1 ? 's' : ''}</span>
                            <div style="font-size: 12px; color: #94a3b8;">
                                <button class="btn btn-sm btn-success" onclick="extendTrial(${c.id}, 1)" style="font-size: 11px; padding: 4px 8px;">+1 Month</button>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            document.getElementById('expiringList').innerHTML = html;
        }
        
        // Filter clients
        function filterClients() {
            const search = document.getElementById('searchClients').value.toLowerCase();
            const rows = document.querySelectorAll('#clientsTableBody tr');
            
            rows.forEach(row => {
                const name = row.getAttribute('data-name');
                if (name.includes(search)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
        
        // Sort clients
        let currentSort = { column: null, direction: 'asc' };
        
        function sortClients(column) {
            const tbody = document.getElementById('clientsTableBody');
            const rows = Array.from(tbody.querySelectorAll('tr'));
            
            // Toggle direction
            if (currentSort.column === column) {
                currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
            } else {
                currentSort.column = column;
                currentSort.direction = 'asc';
            }
            
            // Reset all sort indicators
            document.querySelectorAll('.sortable span').forEach(span => {
                span.textContent = '↕';
            });
            
            // Set current sort indicator
            const sortSpan = document.getElementById('sort-' + column);
            if (sortSpan) {
                sortSpan.textContent = currentSort.direction === 'asc' ? '↑' : '↓';
            }
            
            rows.sort((a, b) => {
                let aVal, bVal;
                
                switch (column) {
                    case 'username':
                        aVal = a.querySelector('td:first-child strong')?.textContent.toLowerCase() || '';
                        bVal = b.querySelector('td:first-child strong')?.textContent.toLowerCase() || '';
                        break;
                    case 'status':
                        // Order: Paid > Trial > Expired
                        const statusOrder = { 'paid': 0, 'trial': 1, 'expired': 2 };
                        aVal = statusOrder[a.querySelector('.badge')?.textContent.toLowerCase()] || 3;
                        bVal = statusOrder[b.querySelector('.badge')?.textContent.toLowerCase()] || 3;
                        break;
                    case 'lastWatched':
                        aVal = a.querySelector('td:nth-child(3)')?.textContent.trim() || 'Never';
                        bVal = b.querySelector('td:nth-child(3)')?.textContent.trim() || 'Never';
                        // Convert to comparable values
                        if (aVal === 'Never') aVal = 'zzz';
                        if (bVal === 'Never') bVal = 'zzz';
                        break;
                    case 'expiry':
                        // Extract expiry date
                        const aExpiry = a.querySelector('.expiry-date')?.textContent || '';
                        const bExpiry = b.querySelector('.expiry-date')?.textContent || '';
                        // Expired first, then by date
                        if (aExpiry === 'EXPIRED') aVal = '0000-00-00';
                        else aVal = aExpiry;
                        if (bExpiry === 'EXPIRED') bVal = '0000-00-00';
                        else bVal = bExpiry;
                        break;
                    default:
                        return 0;
                }
                
                if (currentSort.direction === 'asc') {
                    return aVal < bVal ? -1 : aVal > bVal ? 1 : 0;
                } else {
                    return aVal > bVal ? -1 : aVal < bVal ? 1 : 0;
                }
            });
            
            // Re-append sorted rows
            rows.forEach(row => tbody.appendChild(row));
        }
        
        // Load on page load
        loadExpiringClients();
        loadCreditHistory();
        loadExpiredClientsList();
        
        // Load expired clients from API
        async function loadExpiredClientsList() {
            try {
                const response = await fetch('/reseller/expired-clients');
                if (!response.ok) throw new Error('Failed to load');
                const expiredClients = await response.json();
                
                const container = document.getElementById('expiredClientsList');
                
                if (expiredClients.length === 0) {
                    container.innerHTML = `
                        <div class="empty-state">
                            <div class="empty-state-icon">✅</div>
                            <p>No expired clients</p>
                        </div>
                    `;
                    return;
                }
                
                let html = '';
                expiredClients.forEach(c => {
                    const expiryDate = new Date(c.trialEnd).toLocaleDateString();
                    html += `
                        <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 8px; padding: 12px; margin-bottom: 10px;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                                <strong style="color: #f87171;">${c.username}</strong>
                                <div style="display: flex; gap: 5px;">
                                    <button class="btn btn-sm" onclick="extendTrial(${c.id}, 1)" style="background: rgba(34, 197, 94, 0.2); color: #4ade80;">+1 Month</button>
                                    <button class="btn btn-sm" onclick="extendTrial(${c.id}, 3)" style="background: rgba(234, 179, 8, 0.2); color: #facc15;">+3 Months</button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteClient(${c.id}, '${c.username}')" style="background: rgba(239, 68, 68, 0.3); color: #f87171;">🗑️ Delete</button>
                                </div>
                            </div>
                            <div style="font-size: 12px; color: #94a3b8;">
                                Expired: ${expiryDate}
                            </div>
                        </div>
                    `;
                });
                
                container.innerHTML = html;
            } catch (error) {
                console.error('Error loading expired clients:', error);
                document.getElementById('expiredClientsList').innerHTML = `
                    <div class="empty-state">
                        <div class="empty-state-icon">❌</div>
                        <p>Error loading expired clients</p>
                    </div>
                `;
            }
        }
        
        // Reset client password
        async function resetClientPassword(clientId, username) {
            if (!confirm(`Reset password for "${username}"?`)) return;
            
            const res = await fetch('/reseller/client/reset-password', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({clientId})
            }).then(r => r.json());
            
            if (res.success) {
                alert(`Password reset!\n\nUsername: ${res.username}\nNew Password: ${res.password}\n\nShare this with your client.`);
            } else {
                alert(res.error || 'Failed to reset password');
            }
        }
        
        // Load credit history
        async function loadCreditHistory() {
            try {
                const response = await fetch('/reseller/credit-history');
                if (!response.ok) {
                    throw new Error('Failed to load');
                }
                const history = await response.json();
                const container = document.getElementById('creditHistoryList');
                
                if (history.length === 0) {
                    container.innerHTML = `
                        <div class="empty-state">
                            <div class="empty-state-icon">📋</div>
                            <p>No credit history yet</p>
                        </div>
                    `;
                    return;
                }
                
                let html = '<div style="max-height: 300px; overflow-y: auto;">';
                history.forEach(h => {
                    const amount = h.amount;
                    const isAdd = amount > 0;
                    const date = new Date(h.createdAt).toLocaleDateString();
                    html += `
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; border-bottom: 1px solid rgba(255,255,255,0.1);">
                            <div>
                                <div style="color: ${isAdd ? '#4ade80' : '#f87171'}; font-weight: 600;">
                                    ${isAdd ? '+' : ''}${amount} credits
                                </div>
                                <div style="font-size: 12px; color: #64748b;">${h.note || (isAdd ? 'Added by admin' : 'Used for client')}</div>
                            </div>
                            <div style="font-size: 12px; color: #64748b;">${date}</div>
                        </div>
                    `;
                });
                html += '</div>';
                
                container.innerHTML = html;
            } catch (error) {
                console.error('Error loading credit history:', error);
                document.getElementById('creditHistoryList').innerHTML = `
                    <div class="empty-state">
                        <div class="empty-state-icon">❌</div>
                        <p>Error loading history</p>
                    </div>
                `;
            }
        }
        
        // Toggle client (enable/disable)
        async function toggleClient(clientId, username, isDisabled) {
            const action = isDisabled ? 'enable' : 'disable';
            if (!confirm(`Are you sure you want to ${action} "${username}"?`)) return;
            
            const res = await fetch('/reseller/client/toggle', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({clientId})
            }).then(r => r.json());
            
            if (res.success) {
                alert(`${username} has been ${res.disabled ? 'disabled' : 'enabled'}!`);
                location.reload();
            } else {
                alert(res.error || 'Failed to toggle');
            }
        }
        
        // Delete client
        async function deleteClient(clientId, username) {
            if (!confirm(`Are you sure you want to delete "${username}"? This will also remove them from Jellyfin. This cannot be undone!`)) return;
            
            if (!confirm(`LAST WARNING: Delete "${username}" permanently?`)) return;
            
            const res = await fetch('/reseller/client/delete', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({clientId})
            }).then(r => r.json());
            
            if (res.success) {
                alert('Client deleted successfully');
                location.reload();
            } else {
                alert(res.error || 'Failed to delete');
            }
        }
        
        // Edit client note
        async function editClientNote(clientId, username) {
            document.getElementById('noteClientId').value = clientId;
            document.getElementById('noteClientName').textContent = username;
            
            // Get current note from server
            const res = await fetch(`/reseller/client/${clientId}/credentials`).then(r => r.json());
            document.getElementById('clientNoteText').value = res.note || '';
            
            openModal('noteModal');
        }
        
        // Save client note
        async function saveClientNote() {
            const clientId = document.getElementById('noteClientId').value;
            const note = document.getElementById('clientNoteText').value;
            
            const res = await fetch('/reseller/client/update-note', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({clientId, note})
            }).then(r => r.json());
            
            if (res.success) {
                closeModal('noteModal');
                location.reload();
            } else {
                alert(res.error || 'Failed to save note');
            }
        }
        
        // Show credentials
        let currentCredentials = null;
        async function showCredentials(clientId) {
            const res = await fetch(`/reseller/client/${clientId}/credentials`).then(r => r.json());
            
            if (!res.success) {
                alert(res.error || 'Failed to get credentials');
                return;
            }
            
            currentCredentials = res;
            
            const expiryDate = new Date(res.expires).toLocaleDateString();
            const password = res.password || '(not set - contact admin)';
            
            const html = `
                <div style="background: rgba(255,255,255,0.05); border-radius: 10px; padding: 20px; margin-bottom: 15px;">
                    <div style="margin-bottom: 15px;">
                        <label style="color: #64748b; font-size: 12px; display: block; margin-bottom: 5px;">Jellyfin URL</label>
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <input type="text" value="${res.jellyfinUrl}" readonly style="flex: 1; background: rgba(0,0,0,0.3); font-family: monospace; color: #fff; padding: 8px;">
                            <button class="btn btn-sm" onclick="copyText('${res.jellyfinUrl}', this)">Copy</button>
                        </div>
                    </div>
                    <div style="margin-bottom: 15px;">
                        <label style="color: #64748b; font-size: 12px; display: block; margin-bottom: 5px;">Username</label>
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <input type="text" value="${res.username}" readonly style="flex: 1; background: rgba(0,0,0,0.3); font-family: monospace; color: #fff; padding: 8px;">
                            <button class="btn btn-sm" onclick="copyText('${res.username}', this)">Copy</button>
                        </div>
                    </div>
                    <div style="margin-bottom: 15px;">
                        <label style="color: #64748b; font-size: 12px; display: block; margin-bottom: 5px;">Password</label>
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <input type="text" value="${password}" readonly style="flex: 1; background: rgba(0,0,0,0.3); font-family: monospace; color: #fff; padding: 8px;">
                            <button class="btn btn-sm" onclick="copyText('${password.replace(/'/g, "\\'")}', this)">Copy</button>
                        </div>
                    </div>
                    <div style="padding: 10px; background: rgba(234, 179, 8, 0.1); border-radius: 8px; border: 1px solid rgba(234, 179, 8, 0.3);">
                        <strong style="color: #facc15;">⏰ Expires:</strong> <span style="color: #facc15;">${expiryDate}</span>
                    </div>
                </div>
                <p style="color: #64748b; font-size: 13px; text-align: center;">
                    Share these credentials with your client to access Jellyfin.
                </p>
            `;
            
            document.getElementById('credentialsContent').innerHTML = html;
            openModal('credentialsModal');
        }
        
        // Copy text helper (works on HTTP and HTTPS)
        function copyText(text, btn) {
            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.style.position = 'fixed';
            textarea.style.left = '-9999px';
            textarea.style.top = '0';
            document.body.appendChild(textarea);
            textarea.focus();
            textarea.select();
            
            try {
                document.execCommand('copy');
                const original = btn.innerText;
                btn.innerText = '✓ Done!';
                setTimeout(() => btn.innerText = original, 1500);
            } catch (e) {
                prompt('Copy this text:', text);
            }
            
            document.body.removeChild(textarea);
        }
        
        // Copy all credentials
        function copyCredentials() {
            if (!currentCredentials) return;
            
            const password = currentCredentials.password || '(not set)';
            const expiryDate = new Date(currentCredentials.expires).toLocaleDateString();
            
            const text = `🎬 Jellyfin Login Details

URL: ${currentCredentials.jellyfinUrl}
Username: ${currentCredentials.username}
Password: ${password}

⏰ Expires: ${expiryDate}

Download the Jellyfin app or open the URL in your browser to start streaming!`;
            
            const textarea = document.createElement('textarea');
            textarea.value = text;
            textarea.style.position = 'fixed';
            textarea.style.left = '-9999px';
            textarea.style.top = '0';
            document.body.appendChild(textarea);
            textarea.focus();
            textarea.select();
            
            try {
                document.execCommand('copy');
                alert('✓ Copied to clipboard!');
            } catch (e) {
                prompt('Copy this text:', text);
            }
            
            document.body.removeChild(textarea);
        }
    </script>
</body>
</html>